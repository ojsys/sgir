# SGIR RIGS Feedback System — Production Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your production values.
# Never commit .env to version control.

# ── Database (MySQL — cPanel shared hosting) ──────────────────────────────────
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
# cPanel database name format: cpanelusername_dbname
DB_NAME=cpanelusername_sgir_feedback
# cPanel DB user format: cpanelusername_dbuser
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your_strong_password_here

# ── Company Branding ──────────────────────────────────────────────────────────
COMPANY_NAME="SGIR RIGS"
COMPANY_TAGLINE="Oil Rig Feedback Portal"

# ── Email ─────────────────────────────────────────────────────────────────────
# The From address used in notification emails
MAIL_FROM="noreply@yourdomain.com"
# Comma-separated list of admin emails that receive new feedback alerts
NOTIFICATION_EMAILS="admin@yourdomain.com,manager@yourdomain.com"
