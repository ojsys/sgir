# SGIR RIGS Feedback System вЂ” Apache configuration

# в”Ђв”Ђ Block access to sensitive files в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<FilesMatch "^\.env(\.example)?$|^setup\.php$|^schema.*\.sql$|^database\.sqlite$|^MEMORY\.md$">
    Order allow,deny
    Deny from all
</FilesMatch>

# в”Ђв”Ђ Disable directory listing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Options -Indexes

# в”Ђв”Ђ Protect uploads directory вЂ” no PHP execution в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block PHP execution inside uploads/
    RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|phar)$ - [F,L]
</IfModule>
